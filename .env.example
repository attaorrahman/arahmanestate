# Supabase — get these from your Supabase project dashboard
# Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# DDADS – Dubai Data Access Distribution System (DDA iPaaS)
# Issued by DDADS Support after PUBLICUSER access approval
# STG (test): https://stg-apis.data.dubai   ·   PROD: https://apis.data.dubai
DDADS_TOKEN_URL=https://stg-apis.data.dubai/secure/sdg/ssis/gatewayoauthtoken/1.0.0/getAccessToken
DDADS_API_BASE_URL=https://stg-apis.data.dubai
DDADS_CLIENT_ID=your-client-id-here
DDADS_CLIENT_SECRET=your-client-secret-here
DDADS_SECURITY_APP_ID=your-security-application-identifier-here
DDADS_ENTITY=dld
DDADS_DATASET=dld_transactions-open-api
